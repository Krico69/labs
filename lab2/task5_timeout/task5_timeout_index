<?php

session_start();

const TIMEOUT = 300;

if (isset($_POST['logout'])) {
    session_destroy();
    header('Location: index.php');
    exit;
}

if (isset($_SESSION['user'])) {
    $idle = time() - $_SESSION['last_activity'];

    if ($idle > TIMEOUT) {
        session_destroy();
        session_start(); 
        $expired = true;
    } else {
        $_SESSION['last_activity'] = time();
    }
}

if (isset($_POST['login']) && !empty(trim($_POST['username']))) {
    $_SESSION['user']          = htmlspecialchars(trim($_POST['username']));
    $_SESSION['last_activity'] = time(); 
}

if (!empty($expired)) {
    echo "<div class='expired'>⏰ Сесію завершено через 5 хвилин неактивності. Будь ласка, увійдіть знову.</div>";
}

if (!empty($_SESSION['user'])) {
    $user = $_SESSION['user'];
    $idle = time() - $_SESSION['last_activity'];
    $remaining = TIMEOUT - $idle;

    echo "<p class='greeting'>Привіт, {$user}! 👋</p>";
    echo "<div class='info'>
        ⏱ Сесія активна.<br>
        Час до автовиходу: <strong>{$remaining} сек.</strong><br>
        Остання активність: <strong>" . date('H:i:s', $_SESSION['last_activity']) . "</strong>
    </div>";
    echo "<div class='warning'>ℹ️ Сесія автоматично завершиться через 5 хвилин без активності.</div>";

    echo "
    <form method='POST' style='display:inline;'>
        <button class='btn-primary' name='refresh'>🔄 Оновити активність</button>
        <button class='btn-danger' name='logout'>Вийти</button>
    </form>";
} else {
    echo "<h2>Вхід із таймаутом сесії</h2>";
    echo "<p style='color:#555;'>Сесія автоматично завершиться через <strong>5 хвилин</strong> неактивності.</p>";
    echo "
    <form method='POST'>
        <label>Ваше ім'я</label>
        <input type='text' name='username' placeholder='Наприклад: Марія' maxlength='50'>
        <button class='btn-primary' name='login'>Увійти</button>
    </form>";
}
?>
