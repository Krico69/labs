if (isset($_POST['delete_cookie'])) {
    setcookie('username', '', time() - 3600, '/'); 
    header('Location: index.php');
    exit;
}

if (isset($_POST['submit']) && !empty(trim($_POST['username']))) {
    $name = htmlspecialchars(trim($_POST['username']));
    setcookie('username', $name, time() + 7 * 24 * 60 * 60, '/');
    $_COOKIE['username'] = $name;
}

if (!empty($_COOKIE['username'])) {
    $savedName = htmlspecialchars($_COOKIE['username']);
    echo "<p class='greeting'>Привіт, {$savedName}! Ми вас пам'ятаємо 👋</p>";
    echo "<p>Ваше ім'я збережено в cookie на 7 днів.</p>";
    echo "
    <form method='POST'>
        <button class='btn-danger' name='delete_cookie'>Видалити cookie</button>
    </form>";
} else {
    echo "<h2>Введіть ваше ім'я</h2>";
    echo "
    <form method='POST'>
        <label>Ім'я користувача</label>
        <input type='text' name='username' placeholder='Наприклад: Олег' maxlength='50'>
        <button class='btn-primary' type='submit' name='submit'>Зберегти в cookie</button>
    </form>";
}
